{
  "crons": [
    {
      "path": "/api/cron/sync",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/scheduled/send",
      "schedule": "0 8 * * *"
    }
  ],
  "functions": {
    "app/api/messages/send/route.ts": {
      "maxDuration": 30
    },
    "app/api/cron/sync/route.ts": {
      "maxDuration": 60
    }
  }
}
